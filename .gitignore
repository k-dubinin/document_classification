# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.env/
.env.*
.venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Python packaging
build/
dist/
*.egg-info/
.eggs/

# Logs (см. settings/default.yaml — логи приложения)
*.log
logs/

# Обученные модели в models/ (метрики .json / .png можно коммитить при необходимости)
models/*.joblib
models/*.pkl

# Большие/частные данные (примеры в data/ и sample_train.csv — в репозитории)
data/private/
data/raw/
data/tmp/

# Черновики сканов/картинок вне models (матрицы ошибок в models/*.png можно коммитить)
temp_images/
*.png
!models/*.png
*.jpg
*.jpeg
*.tiff

# Локальные переопределения настроек
settings/local.yaml
settings/*.local.yaml

# Hugging Face / кэши загрузок
.cache/
huggingface/
datasets/

# PyTorch / тяжёлые веса
*.pt
*.bin

# Тесты и покрытие
.coverage
htmlcov/
.pytest_cache/
